{% stylesheet %}
.text-slider-section {
  overflow: hidden;
  background-color: #121535;
  padding: 30px 0;
  position: relative;
}

.text-slider-track {
  display: flex;
  width: max-content;
  animation: scroll-left 10s linear infinite;
}

.text-item {
  display: flex;
  align-items: center;
  gap: 16px;
  color: white;
  font-weight: bold;
  font-size: 32px;
  flex-shrink: 0;
  white-space: nowrap;
  margin-right: 80px;
}

.text-item img {
  width: 24px;
  height: 24px;
}

@keyframes scroll-left {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-50%);
  }
}
{% endstylesheet %}

