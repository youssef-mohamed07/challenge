{% javascript %}
(() => {
  document.addEventListener('DOMContentLoaded', () => {
    const root = document.querySelector('.partner-hub');
    if (!root) return;

    const form = root.querySelector('#PartnerHubContactForm');
    if (!form) return;

    const steps = Array.from(form.querySelectorAll('[data-step-panel]'));
    const indicators = Array.from(form.querySelectorAll('[data-step-indicator]'));
    const nextButtons = Array.from(form.querySelectorAll('[data-step-next]'));
    const prevButtons = Array.from(form.querySelectorAll('[data-step-prev]'));
    const errorBox = form.querySelector('#PartnerStepError');
    const progressBar = form.querySelector('#PartnerProgressBar');
    const selectedProductsField = form.querySelector('#PartnerSelectedProducts');
    const mailtoRecipientField = form.querySelector('#PartnerMailtoRecipient');
    const mailtoSubjectField = form.querySelector('#PartnerMailtoSubject');
    const summaryBox = form.querySelector('#PartnerSummary p');
    const checkboxes = Array.from(form.querySelectorAll('.partner-product-check'));
    const unitSelects = Array.from(form.querySelectorAll('.partner-product-unit'));
    const productCards = Array.from(form.querySelectorAll('[data-product-card]'));
    const categoryButtons = Array.from(form.querySelectorAll('[data-category-filter]'));
    const searchInput = form.querySelector('#PartnerProductSearch');
    const catalogCount = form.querySelector('#PartnerCatalogCount');
    const emptyState = form.querySelector('#PartnerProductsEmpty');
    const loadMoreButton = form.querySelector('#PartnerLoadMoreProducts');
    const catalogInitialLimit = Math.max(Number(root.dataset.catalogInitialLimit) || 8, 1);
    const catalogLoadStep = Math.max(Number(root.dataset.catalogLoadStep) || 8, 1);
    let visibleProductsLimit = catalogInitialLimit;
    let activeCategory = 'all';

    const getStepByNumber = (stepNumber) => steps.find((step) => Number(step.dataset.stepPanel) === stepNumber);
    const getCurrentStepNumber = () => Number(form.dataset.currentStep || 1);
    const normalizeText = (value = '') => value.toString().toLowerCase().trim();

    const setError = (message = '') => {
      if (!errorBox) return;
      if (!message) {
        errorBox.hidden = true;
        errorBox.textContent = '';
        return;
      }
      errorBox.hidden = false;
      errorBox.textContent = message;
    };

    const filterProducts = ({ resetLimit = false } = {}) => {
      if (resetLimit) {
        visibleProductsLimit = catalogInitialLimit;
      }

      const searchTerm = normalizeText(searchInput ? searchInput.value : '');
      const matchedCards = [];

      productCards.forEach((card) => {
        const cardCategory = normalizeText(card.dataset.category || 'other');
        const cardTitle = normalizeText(card.dataset.title || '');
        const matchesCategory = activeCategory === 'all' || cardCategory === activeCategory;
        const matchesSearch = !searchTerm || cardTitle.includes(searchTerm);
        if (matchesCategory && matchesSearch) {
          matchedCards.push(card);
        }
      });

      productCards.forEach((card) => {
        card.classList.add('is-hidden');
      });

      matchedCards.forEach((card, index) => {
        card.classList.toggle('is-hidden', index >= visibleProductsLimit);
      });

      const visibleCount = Math.min(matchedCards.length, visibleProductsLimit);
      if (catalogCount) {
        catalogCount.textContent = `Showing ${visibleCount} of ${matchedCards.length} products`;
      }

      if (emptyState) {
        emptyState.hidden = matchedCards.length > 0;
      }

      if (loadMoreButton) {
        const remainingCount = matchedCards.length - visibleCount;
        loadMoreButton.hidden = remainingCount <= 0;
        if (remainingCount > 0) {
          loadMoreButton.textContent = `Load more products (${remainingCount} more)`;
        }
      }
    };

    const setStep = (stepNumber) => {
      form.dataset.currentStep = String(stepNumber);

      steps.forEach((step) => {
        step.classList.toggle('is-active', Number(step.dataset.stepPanel) === stepNumber);
      });

      indicators.forEach((indicator) => {
        const indicatorStep = Number(indicator.dataset.stepIndicator);
        indicator.classList.toggle('is-active', indicatorStep === stepNumber);
        indicator.classList.toggle('is-complete', indicatorStep < stepNumber);
      });

      if (progressBar) {
        const ratio = steps.length > 0 ? (stepNumber / steps.length) * 100 : 100;
        progressBar.style.width = `${ratio}%`;
      }

      setError('');
      updateSummary();
    };

    const syncProductCardState = (checkbox) => {
      const qtyInput = form.querySelector(`.partner-product-qty[data-qty-for="${checkbox.value}"]`);
      const unitInput = form.querySelector(`.partner-product-unit[data-unit-for="${checkbox.value}"]`);
      if (qtyInput) {
        qtyInput.disabled = !checkbox.checked;
        if (checkbox.checked && Number(qtyInput.value) < 1) {
          qtyInput.value = '1';
        }
      }
      if (unitInput) {
        unitInput.disabled = !checkbox.checked;
      }

      const card = checkbox.closest('[data-product-card]');
      if (card) {
        card.classList.toggle('is-selected', checkbox.checked);
      }
    };

    const validateRequiredFields = (stepElement) => {
      const requiredFields = Array.from(stepElement.querySelectorAll('[required]'));
      for (const field of requiredFields) {
        if ((field.type === 'checkbox' || field.type === 'radio') && !field.checked) {
          field.reportValidity();
          return false;
        }

        if (typeof field.value === 'string' && field.value.trim() === '') {
          field.reportValidity();
          return false;
        }
      }
      return true;
    };

    const getSelectedProductsList = () => {
      const selected = [];
      checkboxes.forEach((checkbox) => {
        if (!checkbox.checked) return;
        const productId = checkbox.value;
        const productTitle = checkbox.dataset.productTitle || 'Product';
        const qtyInput = form.querySelector(`.partner-product-qty[data-qty-for="${productId}"]`);
        const unitInput = form.querySelector(`.partner-product-unit[data-unit-for="${productId}"]`);
        const qty = Math.max(Number(qtyInput ? qtyInput.value : 1) || 1, 1);
        const unit = (unitInput && unitInput.value) || 'Case';
        const unitLabel = qty > 1 ? `${unit}s` : unit;
        selected.push(`${productTitle} - ${qty} ${unitLabel}`);
      });

      const customProducts = (form.querySelector('#Partner-custom-products')?.value || '').trim();
      if (customProducts) {
        selected.push(`Custom notes: ${customProducts}`);
      }

      return selected;
    };

    const syncSelectedProducts = () => {
      const selected = getSelectedProductsList();
      if (selectedProductsField) {
        selectedProductsField.value = selected.join(' | ');
      }
      return selected;
    };

    const validateProductsStep = () => {
      const selected = getSelectedProductsList();
      if (selected.length === 0) {
        setError('Select at least one wholesale product line or add custom product notes before continuing.');
        return false;
      }
      return true;
    };

    const validateStep = (stepNumber) => {
      const step = getStepByNumber(stepNumber);
      if (!step) return false;

      if (!validateRequiredFields(step)) {
        return false;
      }

      if (stepNumber === 2 && !validateProductsStep()) {
        return false;
      }

      setError('');
      return true;
    };

    const getFieldValue = (selector) => {
      const field = form.querySelector(selector);
      return ((field && field.value) || '').trim();
    };

    const buildMailtoLink = () => {
      const recipient = ((mailtoRecipientField && mailtoRecipientField.value) || '').trim().replace(/\s+/g, '');
      if (!recipient) {
        setError('Recipient email is missing. Please set it in Partner Hub section settings.');
        return '';
      }

      const baseSubject = ((mailtoSubjectField && mailtoSubjectField.value) || 'Partner request from storefront').trim();
      const legalName = getFieldValue('#Partner-company-legal');
      const subject = legalName ? `${baseSubject} - ${legalName}` : baseSubject;
      const selectedProducts = getSelectedProductsList();
      const tradeTermsAccepted = form.querySelector('#Partner-trade-terms')?.checked ? 'Accepted' : 'Not accepted';

      const mailLines = [
        'B2B Wholesale RFQ',
        '',
        '=== Company Profile ===',
        `Contact person: ${getFieldValue('#Partner-name') || '-'}`,
        `Business email: ${getFieldValue('#Partner-email') || '-'}`,
        `Phone: ${getFieldValue('#Partner-phone') || '-'}`,
        `Buyer role: ${getFieldValue('#Partner-role') || '-'}`,
        `Company legal name: ${getFieldValue('#Partner-company-legal') || '-'}`,
        `Trading name: ${getFieldValue('#Partner-company') || '-'}`,
        `VAT / Tax ID: ${getFieldValue('#Partner-vat') || '-'}`,
        `Commercial registration: ${getFieldValue('#Partner-registration') || '-'}`,
        `Country: ${getFieldValue('#Partner-country') || '-'}`,
        `Delivery countries: ${getFieldValue('#Partner-delivery-countries') || '-'}`,
        `Website / Social: ${getFieldValue('#Partner-website') || '-'}`,
        '',
        '=== RFQ Product Mix ===',
        `Business type: ${getFieldValue('#Partner-business-type') || '-'}`,
        `Expected monthly spend: ${getFieldValue('#Partner-monthly-spend') || '-'}`,
        `Monthly volume: ${getFieldValue('#Partner-volume') || '-'}`,
        `Selected products: ${selectedProducts.length ? selectedProducts.join(', ') : '-'}`,
        `Custom product notes: ${getFieldValue('#Partner-custom-products') || '-'}`,
        '',
        '=== Commercial & Logistics ===',
        `Payment terms: ${getFieldValue('#Partner-payment-terms') || '-'}`,
        `Payment method: ${getFieldValue('#Partner-payment-method') || '-'}`,
        `Shipping terms: ${getFieldValue('#Partner-shipping-terms') || '-'}`,
        `Delivery city / port: ${getFieldValue('#Partner-destination') || '-'}`,
        `Target PO value: ${getFieldValue('#Partner-budget') || '-'}`,
        `Preferred timeframe: ${getFieldValue('#Partner-timeframe') || '-'}`,
        `Trade terms acceptance: ${tradeTermsAccepted}`,
        '',
        '=== Additional Details ===',
        getFieldValue('#Partner-message') || '-',
        '',
        `Page URL: ${window.location.href}`,
      ];

      const encodedSubject = encodeURIComponent(subject);
      const encodedBody = encodeURIComponent(mailLines.join('\n'));
      return `mailto:${recipient}?subject=${encodedSubject}&body=${encodedBody}`;
    };

    const updateSummary = () => {
      if (!summaryBox) return;
      const selectedProducts = syncSelectedProducts();

      const summary = [
        `Contact: ${form.querySelector('#Partner-name')?.value || '-'}`,
        `Business email: ${form.querySelector('#Partner-email')?.value || '-'}`,
        `Legal name: ${form.querySelector('#Partner-company-legal')?.value || '-'}`,
        `Buyer role: ${form.querySelector('#Partner-role')?.value || '-'}`,
        `VAT / Tax ID: ${form.querySelector('#Partner-vat')?.value || '-'}`,
        `Country: ${form.querySelector('#Partner-country')?.value || '-'}`,
        `Delivery countries: ${form.querySelector('#Partner-delivery-countries')?.value || '-'}`,
        `Business type: ${form.querySelector('#Partner-business-type')?.value || '-'}`,
        `Monthly spend: ${form.querySelector('#Partner-monthly-spend')?.value || '-'}`,
        `Payment terms: ${form.querySelector('#Partner-payment-terms')?.value || '-'}`,
        `Shipping terms: ${form.querySelector('#Partner-shipping-terms')?.value || '-'}`,
        `Selected products: ${selectedProducts.length ? selectedProducts.join(', ') : '-'}`,
      ];

      summaryBox.textContent = summary.join('\n');
    };

    checkboxes.forEach((checkbox) => {
      syncProductCardState(checkbox);
      checkbox.addEventListener('change', () => {
        syncProductCardState(checkbox);
        updateSummary();
      });
    });

    Array.from(form.querySelectorAll('.partner-product-qty')).forEach((qtyInput) => {
      qtyInput.addEventListener('input', () => {
        const numericValue = Math.max(Number(qtyInput.value) || 1, 1);
        qtyInput.value = String(numericValue);
        updateSummary();
      });
    });

    unitSelects.forEach((unitSelect) => {
      unitSelect.addEventListener('change', updateSummary);
    });

    const summaryFields = [
      '#Partner-name',
      '#Partner-email',
      '#Partner-phone',
      '#Partner-role',
      '#Partner-company-legal',
      '#Partner-company',
      '#Partner-vat',
      '#Partner-registration',
      '#Partner-country',
      '#Partner-delivery-countries',
      '#Partner-website',
      '#Partner-business-type',
      '#Partner-monthly-spend',
      '#Partner-payment-terms',
      '#Partner-payment-method',
      '#Partner-shipping-terms',
      '#Partner-destination',
      '#Partner-volume',
      '#Partner-custom-products',
      '#Partner-budget',
      '#Partner-timeframe',
      '#Partner-message',
      '#Partner-trade-terms'
    ];
    summaryFields.forEach((selector) => {
      const field = form.querySelector(selector);
      if (field) {
        field.addEventListener('input', updateSummary);
        field.addEventListener('change', updateSummary);
      }
    });

    categoryButtons.forEach((button) => {
      button.addEventListener('click', () => {
        activeCategory = normalizeText(button.dataset.categoryFilter || 'all');
        categoryButtons.forEach((item) => {
          item.classList.toggle('is-active', item === button);
        });
        filterProducts({ resetLimit: true });
      });
    });

    if (searchInput) {
      searchInput.addEventListener('input', () => {
        filterProducts({ resetLimit: true });
      });
    }

    if (loadMoreButton) {
      loadMoreButton.addEventListener('click', () => {
        visibleProductsLimit += catalogLoadStep;
        filterProducts();
      });
    }

    nextButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const currentStepElement = button.closest('[data-step-panel]');
        const currentStep = Number(currentStepElement?.dataset.stepPanel || getCurrentStepNumber());
        if (!validateStep(currentStep)) return;
        setStep(Math.min(currentStep + 1, steps.length));
      });
    });

    prevButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const currentStepElement = button.closest('[data-step-panel]');
        const currentStep = Number(currentStepElement?.dataset.stepPanel || getCurrentStepNumber());
        setStep(Math.max(currentStep - 1, 1));
      });
    });

    form.addEventListener('submit', (event) => {
      event.preventDefault();

      const currentStep = getCurrentStepNumber();
      if (currentStep !== 3) {
        setStep(3);
        return;
      }

      if (!validateStep(2)) {
        setStep(2);
        return;
      }

      if (!validateStep(3)) {
        return;
      }

      syncSelectedProducts();
      updateSummary();

      const mailtoLink = buildMailtoLink();
      if (!mailtoLink) {
        return;
      }

      window.location.href = mailtoLink;
    });

    filterProducts({ resetLimit: true });
    setStep(1);
  });
})();
{% endjavascript %}

{% schema %}
{
  "name": "Partner Hub",
  "settings": [
    {
      "type": "text",
      "id": "page_title",
      "label": "Page title",
      "default": "Wholesale RFQ and Distributor Program"
    },
    {
      "type": "textarea",
      "id": "page_subtitle",
      "label": "Page subtitle",
      "default": "Submit your business profile and required product mix to receive a wholesale quotation."
    },
    {
      "type": "text",
      "id": "moq_text",
      "label": "MOQ text",
      "default": "From 20 cases per order"
    },
    {
      "type": "text",
      "id": "lead_time_text",
      "label": "Lead time text",
      "default": "3-7 business days"
    },
    {
      "type": "text",
      "id": "payment_terms_text",
      "label": "Payment terms text",
      "default": "Prepaid, Net 15, Net 30"
    },
    {
      "type": "text",
      "id": "response_sla_text",
      "label": "Response SLA text",
      "default": "Within 24 hours"
    },
    {
      "type": "textarea",
      "id": "quote_note",
      "label": "Quote note",
      "default": "Catalog prices are reference only. Final B2B quotation depends on volume, payment terms, and destination."
    },
    {
      "type": "collection",
      "id": "source_collection",
      "label": "Source collection for product picks"
    },
    {
      "type": "checkbox",
      "id": "show_all_products",
      "label": "Show all store products",
      "default": true,
      "info": "Enable to display every product in the RFQ catalog. Disable to use source collection and product limit."
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Number of products to show when all products is disabled",
      "min": 4,
      "max": 24,
      "step": 1,
      "default": 12
    },
    {
      "type": "range",
      "id": "catalog_initial_limit",
      "label": "Initial products to show",
      "min": 4,
      "max": 24,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "catalog_load_more_step",
      "label": "Products to load per click",
      "min": 4,
      "max": 24,
      "step": 1,
      "default": 8
    },
    {
      "type": "text",
      "id": "email_subject",
      "label": "Email subject",
      "default": "B2B Wholesale RFQ from storefront"
    },
    {
      "type": "text",
      "id": "mailto_email",
      "label": "Mailto recipient email",
      "info": "Leave empty to use store email"
    }
  ],
  "presets": [
    {
      "name": "Partner Hub"
    }
  ]
}
{% endschema %}
