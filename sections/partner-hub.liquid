{% assign current_page_handle = page.handle | default: '' %}
{% assign source_collection_handle = section.settings.source_collection %}
{% assign partner_products = collections.all.products %}

{% if section.settings.show_all_products == false and source_collection_handle != blank and collections[source_collection_handle] != blank %}
  {% assign partner_products = collections[source_collection_handle].products %}
{% endif %}

{% if partner_products.size == 0 %}
  {% assign partner_products = collections.all.products %}
{% endif %}

{% assign partner_categories = '' | split: ',' %}
{% for product in partner_products %}
  {% unless section.settings.show_all_products %}
    {% if forloop.index > section.settings.product_limit %}
      {% break %}
    {% endif %}
  {% endunless %}
  {% assign partner_category = product.type | strip %}
  {% if partner_category == blank %}
    {% assign partner_category = 'Other' %}
  {% endif %}
  {% assign partner_category_item = partner_category | split: '|||' %}
  {% assign partner_categories = partner_categories | concat: partner_category_item %}
{% endfor %}
{% assign partner_categories = partner_categories | uniq %}

{% assign partner_mailto_recipient = section.settings.mailto_email | default: shop.email %}

{% if current_page_handle == 'partner-hub' or current_page_handle == 'partner_hub' %}
<section class="partner-hub py-80" data-catalog-initial-limit="{{ section.settings.catalog_initial_limit | default: 8 }}" data-catalog-load-step="{{ section.settings.catalog_load_more_step | default: 8 }}">
  <div class="container container-lg">
    <div class="partner-hub__intro text-center mb-40">
      <span class="partner-hub__eyebrow">B2B Wholesale Portal</span>
      <h1 class="partner-hub__title">{{ section.settings.page_title | escape }}</h1>
      <p class="partner-hub__subtitle">{{ section.settings.page_subtitle | escape }}</p>
    </div>

    <div class="partner-hub__card">
      {% form 'contact', id: 'PartnerHubContactForm', class: 'partner-hub__form' %}
        <input type="hidden" name="contact[subject]" value="{{ section.settings.email_subject | escape }}">
        <input type="hidden" name="contact[note][Request source]" value="Partner Hub Page">
        <input type="hidden" name="contact[note][Requested products]" id="PartnerSelectedProducts" value="">
        <input type="hidden" id="PartnerMailtoRecipient" value="{{ partner_mailto_recipient | escape }}">
        <input type="hidden" id="PartnerMailtoSubject" value="{{ section.settings.email_subject | default: 'Partner request from storefront' | escape }}">

        {%- if form.posted_successfully? -%}
          <div class="partner-hub__alert partner-hub__alert--success mb-20">
            Your request was sent successfully. We will contact you shortly.
          </div>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="partner-hub__alert partner-hub__alert--error mb-20">
            <strong>There is an issue with your submission:</strong>
            <ul class="mb-0 mt-8">
              {%- for field in form.errors -%}
                <li>{{ field | capitalize }} {{ form.errors.messages[field] }}</li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

        <div class="partner-hub__form-shell">
          <aside class="partner-hub__form-aside">
            <p class="partner-hub__aside-kicker">Partner lane</p>
            <h5 class="partner-hub__aside-title">Wholesale request desk</h5>
            <p class="partner-hub__aside-copy">Share what you need and get a tailored offer quickly.</p>
            <div class="partner-hub__aside-badges" aria-hidden="true">
              <span>Fast response</span>
              <span>Flexible MOQ</span>
              <span>Custom bundles</span>
              <span>Direct support</span>
            </div>
            <div class="partner-hub__aside-stats" aria-hidden="true">
              <article>
                <strong>24h</strong>
                <span>Average reply</span>
              </article>
              <article>
                <strong>120+</strong>
                <span>Wholesale partners</span>
              </article>
            </div>
            <div class="partner-hub__trust-note">Built for gyms, nutrition stores, and distributors.</div>
          </aside>

          <div class="partner-hub__form-main">
            <div class="partner-hub__trade-strip mb-16" role="list" aria-label="Commercial terms">
              <article role="listitem">
                <strong>MOQ</strong>
                <span>{{ section.settings.moq_text | escape }}</span>
              </article>
              <article role="listitem">
                <strong>Lead time</strong>
                <span>{{ section.settings.lead_time_text | escape }}</span>
              </article>
              <article role="listitem">
                <strong>Payment</strong>
                <span>{{ section.settings.payment_terms_text | escape }}</span>
              </article>
              <article role="listitem">
                <strong>SLA</strong>
                <span>{{ section.settings.response_sla_text | escape }}</span>
              </article>
            </div>

            <p class="partner-hub__quote-note mb-14">{{ section.settings.quote_note | escape }}</p>

            <div class="partner-hub__quick-actions mb-18">
              <a class="partner-hub__btn partner-hub__btn--ghost" href="mailto:{{ partner_mailto_recipient | escape }}?subject={{ 'Request sample pack' | url_encode }}">Request Sample Pack</a>
              <a class="partner-hub__btn partner-hub__btn--ghost" href="mailto:{{ partner_mailto_recipient | escape }}?subject={{ 'Book wholesale call' | url_encode }}">Book Wholesale Call</a>
            </div>

            <div class="partner-hub__progress mb-20" aria-hidden="true">
              <span id="PartnerProgressBar"></span>
            </div>

            <div class="partner-hub__stepper mb-28" role="list" aria-label="Form Steps">
              <div class="partner-hub__stepper-item is-active" data-step-indicator="1" role="listitem">
                <span>1</span>
                <strong>Company</strong>
              </div>
              <div class="partner-hub__stepper-item" data-step-indicator="2" role="listitem">
                <span>2</span>
                <strong>RFQ Items</strong>
              </div>
              <div class="partner-hub__stepper-item" data-step-indicator="3" role="listitem">
                <span>3</span>
                <strong>Commercial</strong>
              </div>
            </div>

            <div class="partner-hub__step is-active" data-step-panel="1">
          <h6 class="partner-hub__section-title">Company profile</h6>
          <div class="row gy-4">
            <div class="col-md-6 partner-hub__field">
              <label class="partner-hub__label" for="Partner-name">Contact person *</label>
              <input id="Partner-name" class="common-input px-16" type="text" name="contact[name]" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" placeholder="Example: Pierre Dubois" required>
            </div>
            <div class="col-md-6 partner-hub__field">
              <label class="partner-hub__label" for="Partner-email">Business email *</label>
              <input id="Partner-email" class="common-input px-16" type="email" name="contact[email]" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" placeholder="Example: achats@nutritionparis.fr" required>
            </div>
            <div class="col-md-6 partner-hub__field">
              <label class="partner-hub__label" for="Partner-phone">Phone *</label>
              <input id="Partner-phone" class="common-input px-16" type="tel" name="contact[phone]" value="{% if form.phone %}{{ form.phone }}{% endif %}" placeholder="Example: +33 6 12 34 56 78" required>
            </div>
            <div class="col-md-6 partner-hub__field">
              <label class="partner-hub__label" for="Partner-role">Buyer role *</label>
              <select id="Partner-role" class="common-input px-16" name="contact[note][Buyer role]" required>
                <option value="">Select (e.g. Responsable Achats)</option>
                <option value="Owner">Owner</option>
                <option value="Procurement Manager">Procurement Manager</option>
                <option value="Operations Manager">Operations Manager</option>
                <option value="Retail Buyer">Retail Buyer</option>
                <option value="Distributor">Distributor</option>
              </select>
            </div>
            <div class="col-md-6 partner-hub__field">
              <label class="partner-hub__label" for="Partner-company-legal">Company legal name *</label>
              <input id="Partner-company-legal" class="common-input px-16" type="text" name="contact[note][Company legal name]" placeholder="Example: NutriForme Distribution SAS" required>
            </div>
            <div class="col-md-6 partner-hub__field">
              <label class="partner-hub__label" for="Partner-company">Trading brand / store name</label>
              <input id="Partner-company" class="common-input px-16" type="text" name="contact[note][Trading name]" placeholder="Example: Salle Energie Paris">
            </div>
            <div class="col-md-6 partner-hub__field">
              <label class="partner-hub__label" for="Partner-vat">VAT / Tax ID *</label>
              <input id="Partner-vat" class="common-input px-16" type="text" name="contact[note][VAT / Tax ID]" placeholder="Example: FR40303265045" required>
            </div>
            <div class="col-md-6 partner-hub__field">
              <label class="partner-hub__label" for="Partner-registration">Commercial registration no. *</label>
              <input id="Partner-registration" class="common-input px-16" type="text" name="contact[note][Commercial registration]" placeholder="Example: RCS Paris B 552 100 554" required>
            </div>
            <div class="col-md-6 partner-hub__field">
              <label class="partner-hub__label" for="Partner-country">Country *</label>
              <input id="Partner-country" class="common-input px-16" type="text" name="contact[note][Country]" placeholder="Example: France" required>
            </div>
            <div class="col-md-6 partner-hub__field">
              <label class="partner-hub__label" for="Partner-delivery-countries">Delivery countries *</label>
              <input id="Partner-delivery-countries" class="common-input px-16" type="text" name="contact[note][Delivery countries]" placeholder="Example: France, Belgique, Suisse" required>
            </div>
            <div class="col-md-6 partner-hub__field">
              <label class="partner-hub__label" for="Partner-website">Website / Social</label>
              <input id="Partner-website" class="common-input px-16" type="text" name="contact[note][Website]" placeholder="Example: https://instagram.com/nutritionparis">
            </div>
          </div>
          <div class="partner-hub__actions mt-24">
            <button type="button" class="partner-hub__btn partner-hub__btn--primary" data-step-next>Next Step</button>
          </div>
        </div>

            <div class="partner-hub__step" data-step-panel="2">
          <h6 class="partner-hub__section-title">RFQ products and terms</h6>
          <p class="partner-hub__section-subtitle">Browse the catalog, filter by category, and select your wholesale mix.</p>

          <div class="partner-hub__catalog-head mb-12">
            <div>
              <p class="partner-hub__catalog-title">Product catalog</p>
              <span class="partner-hub__catalog-count" id="PartnerCatalogCount">Showing {{ partner_products.size }} products</span>
            </div>
            <div class="partner-hub__catalog-search-wrap">
              <label class="visually-hidden" for="PartnerProductSearch">Search products</label>
              <input id="PartnerProductSearch" class="partner-hub__catalog-search" type="search" placeholder="Search products by name">
            </div>
          </div>

          <div class="partner-hub__category-chips mb-16" role="tablist" aria-label="Product categories">
            <button type="button" class="partner-hub__chip is-active" data-category-filter="all">All categories</button>
            {% for category in partner_categories %}
              {% if category != blank %}
                <button type="button" class="partner-hub__chip" data-category-filter="{{ category | handleize }}">{{ category }}</button>
              {% endif %}
            {% endfor %}
          </div>

          <div class="partner-hub__products-grid mb-12" id="PartnerProductsGrid">
            {% for product in partner_products %}
              {% unless section.settings.show_all_products %}
                {% if forloop.index > section.settings.product_limit %}
                  {% break %}
                {% endif %}
              {% endunless %}
              {% assign product_category = product.type | strip %}
              {% if product_category == blank %}
                {% assign product_category = 'Other' %}
              {% endif %}
              <article class="partner-product" data-product-card data-category="{{ product_category | handleize }}" data-title="{{ product.title | downcase | escape }}">
                <a href="{{ product.url }}" class="partner-product__thumb">
                  {% if product.featured_image %}
                    <img src="{{ product.featured_image | image_url: width: 380, height: 280 }}" alt="{{ product.title | escape }}" width="190" height="140" loading="lazy">
                  {% else %}
                    {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {% endif %}
                </a>

                <div class="partner-product__body">
                  <div class="partner-product__meta">
                    <span class="partner-product__badge">{{ product_category }}</span>
                    <span class="partner-product__sku">
                      {% if product.selected_or_first_available_variant.sku != blank %}
                        SKU: {{ product.selected_or_first_available_variant.sku }}
                      {% elsif product.vendor != blank %}
                        {{ product.vendor }}
                      {% else %}
                        {{ shop.name }}
                      {% endif %}
                    </span>
                  </div>
                  <h6 class="partner-product__title">
                    <a href="{{ product.url }}">{{ product.title }}</a>
                  </h6>
                  <p class="partner-product__price">
                    {{ product.price | money }}
                    {% if product.compare_at_price > product.price %}
                      <span>{{ product.compare_at_price | money }}</span>
                    {% endif %}
                  </p>

                  <div class="partner-product__controls">
                    <label class="partner-product__check" for="PartnerProduct-{{ forloop.index }}">
                      <input id="PartnerProduct-{{ forloop.index }}" class="partner-product-check" type="checkbox" value="{{ product.id }}" data-product-title="{{ product.title | escape }}">
                      <span>Select</span>
                    </label>

                    <div class="partner-product__unit-wrap">
                      <label for="PartnerUnit-{{ forloop.index }}">Unit</label>
                      <select id="PartnerUnit-{{ forloop.index }}" class="partner-product-unit" data-unit-for="{{ product.id }}" disabled>
                        <option value="Case">Case</option>
                        <option value="Carton">Carton</option>
                        <option value="Pallet">Pallet</option>
                      </select>
                    </div>

                    <div class="partner-product__qty-wrap">
                      <label for="PartnerQty-{{ forloop.index }}">Count</label>
                      <input id="PartnerQty-{{ forloop.index }}" class="partner-product-qty" type="number" min="1" value="1" data-qty-for="{{ product.id }}" disabled>
                    </div>
                  </div>
                </div>
              </article>
            {% endfor %}
          </div>
          <div class="partner-hub__catalog-actions mb-20" id="PartnerCatalogActions">
            <button type="button" class="partner-hub__btn partner-hub__btn--ghost partner-hub__btn--compact" id="PartnerLoadMoreProducts" hidden>Load more products</button>
          </div>
          <p class="partner-hub__empty-state mb-20" id="PartnerProductsEmpty" hidden>No products matched this filter. Try another category or search term.</p>

          <div class="row gy-4">
            <div class="col-md-6 partner-hub__field">
              <label class="partner-hub__label" for="Partner-business-type">Business type *</label>
              <select id="Partner-business-type" class="common-input px-16" name="contact[note][Business type]" required>
                <option value="">Select (e.g. Salle de sport)</option>
                <option value="Gym">Gym</option>
                <option value="Retail Store">Retail Store</option>
                <option value="Coach / Trainer">Coach / Trainer</option>
                <option value="Online Store">Online Store</option>
                <option value="Distributor">Distributor</option>
                <option value="Other">Other</option>
              </select>
            </div>
            <div class="col-md-6 partner-hub__field">
              <label class="partner-hub__label" for="Partner-monthly-spend">Expected monthly spend *</label>
              <select id="Partner-monthly-spend" class="common-input px-16" name="contact[note][Expected monthly spend]" required>
                <option value="">Select (e.g. 2 000 - 10 000 EUR)</option>
                <option value="Under 2,000">Under 2,000</option>
                <option value="2,000 - 10,000">2,000 - 10,000</option>
                <option value="10,000 - 50,000">10,000 - 50,000</option>
                <option value="50,000+">50,000+</option>
              </select>
            </div>
            <div class="col-md-6 partner-hub__field">
              <label class="partner-hub__label" for="Partner-payment-terms">Preferred payment terms *</label>
              <select id="Partner-payment-terms" class="common-input px-16" name="contact[note][Payment terms]" required>
                <option value="">Select (e.g. 30 jours fin de mois)</option>
                <option value="Prepaid">Prepaid</option>
                <option value="Net 15">Net 15</option>
                <option value="Net 30">Net 30</option>
                <option value="Letter of credit">Letter of credit</option>
              </select>
            </div>
            <div class="col-md-6 partner-hub__field">
              <label class="partner-hub__label" for="Partner-payment-method">Preferred payment method *</label>
              <select id="Partner-payment-method" class="common-input px-16" name="contact[note][Payment method]" required>
                <option value="">Select (e.g. Virement bancaire)</option>
                <option value="Bank transfer">Bank transfer</option>
                <option value="Card">Card</option>
                <option value="Cash on delivery">Cash on delivery</option>
                <option value="Other">Other</option>
              </select>
            </div>
            <div class="col-md-6 partner-hub__field">
              <label class="partner-hub__label" for="Partner-shipping-terms">Shipping terms *</label>
              <select id="Partner-shipping-terms" class="common-input px-16" name="contact[note][Shipping terms]" required>
                <option value="">Select (e.g. DAP Paris)</option>
                <option value="EXW">EXW</option>
                <option value="FOB">FOB</option>
                <option value="CIF">CIF</option>
                <option value="DDP">DDP</option>
              </select>
            </div>
            <div class="col-md-6 partner-hub__field">
              <label class="partner-hub__label" for="Partner-destination">Delivery city / port *</label>
              <input id="Partner-destination" class="common-input px-16" type="text" name="contact[note][Delivery destination]" placeholder="Example: Port du Havre" required>
            </div>
            <div class="col-12 partner-hub__field">
              <label class="partner-hub__label" for="Partner-volume">Expected monthly volume</label>
              <select id="Partner-volume" class="common-input px-16" name="contact[note][Monthly volume]">
                <option value="">Select (optional)</option>
                <option value="Small (1-20 units)">Small (1-20 units)</option>
                <option value="Medium (21-100 units)">Medium (21-100 units)</option>
                <option value="Large (100+ units)">Large (100+ units)</option>
              </select>
            </div>
            <div class="col-12 partner-hub__field">
              <label class="partner-hub__label" for="Partner-custom-products">Custom product notes</label>
              <textarea id="Partner-custom-products" class="common-input px-16" rows="4" name="contact[note][Custom products]" placeholder="Example: 40 whey vanille + 20 creatine citron"></textarea>
            </div>
          </div>

          <div class="partner-hub__actions mt-24">
            <button type="button" class="partner-hub__btn partner-hub__btn--ghost" data-step-prev>Back</button>
            <button type="button" class="partner-hub__btn partner-hub__btn--primary" data-step-next>Review RFQ</button>
          </div>
        </div>

            <div class="partner-hub__step" data-step-panel="3">
          <h6 class="partner-hub__section-title">Finalize commercial request</h6>
          <div class="row gy-4">
            <div class="col-md-6 partner-hub__field">
              <label class="partner-hub__label" for="Partner-budget">Target PO value</label>
              <select id="Partner-budget" class="common-input px-16" name="contact[note][Budget range]">
                <option value="Not specified">Not specified (e.g. 500 - 2 000 EUR)</option>
                <option value="Under 500">Under 500</option>
                <option value="500 - 2,000">500 - 2,000</option>
                <option value="2,000 - 10,000">2,000 - 10,000</option>
                <option value="10,000+">10,000+</option>
              </select>
            </div>
            <div class="col-md-6 partner-hub__field">
              <label class="partner-hub__label" for="Partner-timeframe">Preferred timeframe *</label>
              <select id="Partner-timeframe" class="common-input px-16" name="contact[note][Timeframe]" required>
                <option value="">Select (e.g. Sous 2 semaines)</option>
                <option value="ASAP">ASAP</option>
                <option value="Within 2 weeks">Within 2 weeks</option>
                <option value="Within 1 month">Within 1 month</option>
                <option value="Flexible">Flexible</option>
              </select>
            </div>
            <div class="col-12 partner-hub__field">
              <label class="partner-hub__label" for="Partner-message">Additional details *</label>
              <textarea id="Partner-message" class="common-input px-16" rows="5" name="contact[body]" placeholder="Example: Livraison hebdomadaire a Lyon, saveurs mixtes, option marque blanche." required></textarea>
            </div>
            <div class="col-12 partner-hub__field partner-hub__field--inline">
              <label class="partner-hub__checkline" for="Partner-trade-terms">
                <input id="Partner-trade-terms" type="checkbox" name="contact[note][Trade terms acceptance]" value="Accepted" required>
                <span>I confirm these details are for wholesale purchasing and accept commercial discussion based on MOQ, payment terms, and destination.</span>
              </label>
            </div>
          </div>

          <div class="partner-hub__summary mt-20" id="PartnerSummary">
            <h6>RFQ summary</h6>
            <p class="mb-0">Your selected information will appear here before sending.</p>
          </div>

          <div class="partner-hub__next-steps mt-16">
            <h6>What happens next</h6>
            <ol>
              <li>Within 24 hours, the wholesale desk reviews your company profile.</li>
              <li>Within 48 hours, you receive a tailored quote with terms and lead time.</li>
              <li>After your confirmation, procurement and logistics are scheduled.</li>
            </ol>
          </div>

          <p class="partner-hub__step-error mt-14" id="PartnerStepError" hidden></p>

          <div class="partner-hub__actions mt-24">
            <button type="button" class="partner-hub__btn partner-hub__btn--ghost" data-step-prev>Back</button>
            <button type="submit" class="partner-hub__btn partner-hub__btn--primary">Open Email Draft</button>
          </div>
          <p class="partner-hub__mail-hint mt-12 mb-0">Click Open Email Draft to open your mail app with a complete RFQ ready to send.</p>
        </div>
          </div>
        </div>
      {% endform %}
    </div>
  </div>
</section>
{% endif %}

{% stylesheet %}
.partner-hub {
  background:
    radial-gradient(760px 340px at -5% -10%, rgba(24, 164, 194, 0.2), transparent 70%),
    radial-gradient(620px 320px at 106% 0%, rgba(255, 126, 44, 0.12), transparent 64%),
    linear-gradient(180deg, #f5fbff 0%, #ebf6ff 48%, #f8fcff 100%);
}

.partner-hub__intro {
  max-width: 860px;
  margin-inline: auto;
}

.partner-hub__eyebrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 32px;
  padding: 6px 16px;
  border-radius: 999px;
  background: rgba(17, 138, 178, 0.14);
  color: #116a88;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.7px;
  text-transform: uppercase;
}

.partner-hub__title {
  margin: 14px 0 10px;
  font-family: var(--heading-font-two);
  font-size: clamp(1.85rem, 3.4vw, 3rem);
  font-weight: 900;
  color: var(--neutral-600);
}

.partner-hub__subtitle {
  margin: 0;
  color: var(--gray-700);
  font-size: 16px;
  line-height: 1.65;
}

.partner-hub__card {
  background: rgba(255, 255, 255, 0.97);
  border: 1px solid #d8e8f7;
  border-radius: 26px;
  padding: clamp(16px, 2.4vw, 24px);
  box-shadow:
    0 26px 50px rgba(9, 45, 71, 0.11),
    inset 0 1px 0 rgba(255, 255, 255, 0.8);
}

.partner-hub__form-shell {
  display: grid;
  grid-template-columns: minmax(250px, 320px) 1fr;
  gap: 18px;
  align-items: start;
}

.partner-hub__form-aside {
  background:
    radial-gradient(300px 130px at 100% -10%, rgba(255, 255, 255, 0.2), transparent 65%),
    linear-gradient(160deg, #0f6e8d 0%, #1284a7 50%, #2096bc 100%);
  border-radius: 20px;
  padding: 18px 16px;
  color: #e8f9ff;
  display: grid;
  align-content: flex-start;
  gap: 12px;
  align-self: start;
}

.partner-hub__aside-kicker {
  margin: 0;
  display: inline-flex;
  width: fit-content;
  min-height: 28px;
