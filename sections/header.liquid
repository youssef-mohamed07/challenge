{% style %}
.header .nav-menu .nav-menu__item.activePage > a,
.header .nav-menu .nav-menu__item.activePage > .nav-menu__link,
.header .nav-menu .nav-menu__item.activePage a.nav-menu__link,
.header-menu .nav-menu .nav-menu__item.activePage > a,
.header-menu .nav-menu .nav-menu__item.activePage > .nav-menu__link,
.header-menu .nav-menu .nav-menu__item.activePage a.nav-menu__link,
.nav-menu__item[data-force-active="true"] > a,
.nav-menu__item[data-force-active="true"] > .nav-menu__link,
.nav-menu__item[data-force-active="true"] a.nav-menu__link {
    color: #2394be !important;
    font-weight: 700 !important;
    position: relative !important;
}

.mobile-menu .nav-menu--mobile .nav-menu__item.activePage > a,
.mobile-menu .nav-menu--mobile .nav-menu__item.activePage > .nav-menu__link,
.mobile-menu .nav-menu--mobile .nav-menu__item.activePage a.nav-menu__link,
.mobile-menu .nav-menu--mobile .nav-menu__item[data-force-active="true"] > a,
.mobile-menu .nav-menu--mobile .nav-menu__item[data-force-active="true"] > .nav-menu__link,
.mobile-menu .nav-menu--mobile .nav-menu__item[data-force-active="true"] a.nav-menu__link {
    color: #2394be !important;
    font-weight: 700 !important;
    background-color: rgba(35, 148, 190, 0.1) !important;
    border-radius: 6px !important;
    padding-inline-start: 16px !important;
    border-left: 4px solid #2394be !important;
    margin: 2px 0 !important;
}

.mobile-menu .nav-menu--mobile .nav-submenu__item.activePage > a,
.mobile-menu .nav-menu--mobile .nav-submenu__item.activePage > .nav-submenu__link,
.mobile-menu .nav-menu--mobile .nav-submenu__item.activePage a.nav-submenu__link,
.mobile-menu .nav-menu--mobile .nav-submenu__item[data-force-active="true"] > a,
.mobile-menu .nav-menu--mobile .nav-submenu__item[data-force-active="true"] > .nav-submenu__link,
.mobile-menu .nav-menu--mobile .nav-submenu__item[data-force-active="true"] a.nav-submenu__link {
    color: #2394be !important;
    font-weight: 700 !important;
    background-color: rgba(35, 148, 190, 0.1) !important;
    border-radius: 6px !important;
    padding-inline-start: 20px !important;
    border-left: 3px solid #2394be !important;
    margin: 2px 0 !important;
}

body .header .nav-menu .nav-menu__item.activePage > a,
body .header-menu .nav-menu .nav-menu__item.activePage > a,
body .nav-menu__item[data-force-active="true"] > a {
    color: #2394be !important;
    font-weight: 700 !important;
}

.browseCat.category-dropdown .d-grid,
.category-dropdown .d-grid {
    display: grid !important;
    grid-template-columns: repeat(3, 1fr) !important;
    gap: 16px !important;
}

.d-grid.grid-cols-3-repeat,
.d-grid[class*="grid-cols"] {
    grid-template-columns: repeat(3, 1fr) !important;
}

@media (min-width: 992px) {
    .category-dropdown {
        max-width: 600px !important;
        width: 600px !important;
    }
    
    .browseCat.category-dropdown .d-grid,
    .category-dropdown .d-grid,
    .d-grid.grid-cols-3-repeat,
    .d-grid[class*="grid-cols"] {
        grid-template-columns: repeat(3, 1fr) !important;
        gap: 16px !important;
    }
    
    .category-dropdown a.py-16.px-8 {
        padding: 16px 8px !important;
        min-height: 120px !important;
        display: flex !important;
        flex-direction: column !important;
        align-items: center !important;
        justify-content: center !important;
    }
}

@media (max-width: 991.98px) {
    .category-dropdown {
        position: fixed !important;
        top: 50% !important;
        left: 50% !important;
        transform: translate(-50%, -50%) !important;
        width: 90vw !important;
        max-width: 350px !important;
        max-height: 70vh !important;
        overflow-y: auto !important;
        z-index: 9999 !important;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3) !important;
        border-radius: 12px !important;
        animation: categoryFadeIn 0.3s ease-out;
        display: none;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
    }
    
    @keyframes categoryFadeIn {
        from {
            opacity: 0;
            transform: translate(-50%, -50%) scale(0.9);
        }
        to {
            opacity: 1;
            transform: translate(-50%, -50%) scale(1);
        }
    }
    
    .category-dropdown .d-grid {
        grid-template-columns: repeat(2, 1fr) !important;
        max-height: calc(70vh - 100px) !important;
        overflow-y: auto !important;
        scrollbar-width: thin !important;
        scrollbar-color: #2394be #f1f1f1 !important;
    }
    
    .category-dropdown .d-grid::-webkit-scrollbar {
        width: 6px !important;
    }
    
    .category-dropdown .d-grid::-webkit-scrollbar-track {
        background: #f1f1f1 !important;
        border-radius: 3px !important;
    }
    
    .category-dropdown .d-grid::-webkit-scrollbar-thumb {
        background: #2394be !important;
        border-radius: 3px !important;
    }
    
    .category-dropdown .d-grid::-webkit-scrollbar-thumb:hover {
        background: #1e7a9e !important;
    }
    
    .category-dropdown .py-16 {
        padding-top: 12px !important;
        padding-bottom: 12px !important;
    }
    
    .category-dropdown .px-8 {
        padding-left: 6px !important;
        padding-right: 6px !important;
    }
    
    .category-dropdown .w-40 {
        width: 30px !important;
        height: 30px !important;
    }
    
    .category-dropdown .text-sm {
        font-size: 0.75rem !important;
    }
    
    .category-dropdown .mt-16 {
        margin-top: 8px !important;
    }
    
    .category-overlay.active {
        display: block;
    }
    
    .category-dropdown.show {
        display: block !important;
        opacity: 1 !important;
        visibility: visible !important;
    }
}

@media (max-width: 575.98px) {
    .category-dropdown {
        width: 95vw !important;
        max-height: 80vh !important;
    }
    
    .category-dropdown .d-grid {
        grid-template-columns: repeat(1, 1fr) !important;
        gap: 8px !important;
    }
}

.category-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 9998;
}
{% endstyle %}

