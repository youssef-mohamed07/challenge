<script>
(function() {
    'use strict';
    
    let activeElement = null;
    const currentPath = window.location.pathname.toLowerCase();
    
    function forceActiveNavbar() {
        if (activeElement) {
            activeElement.classList.remove('activePage');
        }
        
        document.querySelectorAll('.nav-menu__item').forEach(item => {
            const link = item.querySelector('a');
            if (link) {
                const href = link.getAttribute('href');
                if (href) {
                    const normalizedHref = href.toLowerCase().replace(/\/$/, '') || '/';
                    const normalizedCurrent = currentPath.replace(/\/$/, '') || '/';
                    
                    if (normalizedHref === normalizedCurrent) {
                        activeElement = item;
                        item.classList.add('activePage');
                        item.setAttribute('data-force-active', 'true');
                    } else if (currentPath.startsWith('/collections/') && 
                             (normalizedHref === '/collections/all' || normalizedHref === '/collections')) {
                        activeElement = item;
                        item.classList.add('activePage');
                        item.setAttribute('data-force-active', 'true');
                    } else if (currentPath.startsWith('/products/') && 
                             (normalizedHref === '/collections/all' || normalizedHref === '/collections')) {
                        activeElement = item;
                        item.classList.add('activePage');
                        item.setAttribute('data-force-active', 'true');
                    }
                }
            }
        });
    }
    
    const observer = new MutationObserver(function(mutations) {
        mutations.forEach(function(mutation) {
            if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
                const target = mutation.target;
                if (target.hasAttribute('data-force-active') && !target.classList.contains('activePage')) {
                    target.classList.add('activePage');
                }
            }
        });
    });
    
    function startObserver() {
        document.querySelectorAll('.nav-menu__item').forEach(item => {
            observer.observe(item, { attributes: true, attributeFilter: ['class'] });
        });
    }
    
    forceActiveNavbar();
    startObserver();
    
    document.addEventListener('DOMContentLoaded', function() {
        forceActiveNavbar();
        startObserver();
    });
    
    window.addEventListener('load', function() {
        forceActiveNavbar();
        startObserver();
    });
    
    let persistentCheckCount = 0;
    const persistentInterval = setInterval(function() {
        if (persistentCheckCount < 50) {
            if (activeElement && !activeElement.classList.contains('activePage')) {
                activeElement.classList.add('activePage');
            }
            persistentCheckCount++;
        } else {
            clearInterval(persistentInterval);
        }
    }, 100);
})();

(function() {
    'use strict';
    
    const categoryButton = document.querySelector('.category-button');
    const categoryDropdown = document.querySelector('.category-dropdown');
    const categoryOverlay = document.querySelector('.category-overlay');
    const categoryCloseBtn = document.querySelector('.category-close-btn');
    
    if (!categoryButton || !categoryDropdown || !categoryOverlay) return;
    
    let isOpen = false;
    
    function toggleCategoryDropdown() {
        isOpen = !isOpen;
        
        if (isOpen) {
            categoryDropdown.classList.add('show');
            categoryOverlay.classList.add('active');
            document.body.style.overflow = 'hidden';
        } else {
            categoryDropdown.classList.remove('show');
            categoryOverlay.classList.remove('active');
            document.body.style.overflow = '';
        }
    }
    
    function closeCategoryDropdown() {
        if (isOpen) {
            isOpen = false;
            categoryDropdown.classList.remove('show');
            categoryOverlay.classList.remove('active');
            document.body.style.overflow = '';
        }
    }
    
    categoryButton.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        toggleCategoryDropdown();
    });
    
    categoryOverlay.addEventListener('click', closeCategoryDropdown);
    
    if (categoryCloseBtn) {
        categoryCloseBtn.addEventListener('click', closeCategoryDropdown);
    }
    
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && isOpen) {
            closeCategoryDropdown();
        }
    });
    
    document.addEventListener('click', function(e) {
        if (window.innerWidth > 991 && isOpen && !categoryDropdown.contains(e.target) && !categoryButton.contains(e.target)) {
            closeCategoryDropdown();
        }
    });
    
    window.addEventListener('resize', function() {
        if (window.innerWidth > 991 && isOpen) {
            closeCategoryDropdown();
        }
    });
})();

(function() {
    'use strict';
    
    const updateCartCount = async () => {
        try {
            const response = await fetch('/cart.js');
            const cart = await response.json();
            const cartCountElements = document.querySelectorAll('.cart-count, [data-cart-count]');
            
            cartCountElements.forEach(element => {
                element.textContent = cart.item_count;
            });
        } catch (error) {
            console.error('Error updating cart count:', error);
        }
    };
    
    document.addEventListener('cart:updated', updateCartCount);
    document.addEventListener('cart:item-added', updateCartCount);
    document.addEventListener('cart:item-removed', updateCartCount);
    document.addEventListener('cart:item-changed', updateCartCount);
    
    window.updateCartCount = updateCartCount;
})();
</script>
