{% assign site_logo_asset = 'logo.webp' | asset_url %}
{% assign hot_deals_url = routes.root_url | append: 'pages/hot-deals' %}
{% assign our_brands_url = routes.root_url | append: 'pages/our-brands' %}
{% assign partner_hub_page = pages['partner_hub'] %}
{% if partner_hub_page == blank %}
    {% assign partner_hub_page = pages['partner-hub'] %}
{% endif %}
{% assign partner_hub_url_fallback = routes.root_url | append: 'pages/partner_hub' %}
{% assign partner_hub_url = partner_hub_page.url | default: partner_hub_url_fallback %}
{% assign hot_deals_title = 'Hot Deals' %}
{% assign our_brands_title = 'Our Brands' %}
{% assign partner_hub_title = 'Partner Hub' %}

{% assign has_hot_deals_link = false %}
{% assign has_our_brands_link = false %}
{% assign has_partner_hub_link = false %}
{% for link in linklists.main-menu.links %}
    {% assign link_path = link.url | downcase %}
    {% if link_path contains '/pages/hot-deals' %}
        {% assign has_hot_deals_link = true %}
    {% endif %}
    {% if link_path contains '/pages/our-brands' %}
        {% assign has_our_brands_link = true %}
    {% endif %}
    {% if link_path contains '/pages/partner_hub' or link_path contains '/pages/partner-hub' %}
        {% assign has_partner_hub_link = true %}
    {% endif %}

    {% if link.links.size > 0 %}
        {% for sublink in link.links %}
            {% assign sublink_path = sublink.url | downcase %}
            {% if sublink_path contains '/pages/hot-deals' %}
                {% assign has_hot_deals_link = true %}
            {% endif %}
            {% if sublink_path contains '/pages/our-brands' %}
                {% assign has_our_brands_link = true %}
            {% endif %}
            {% if sublink_path contains '/pages/partner_hub' or sublink_path contains '/pages/partner-hub' %}
                {% assign has_partner_hub_link = true %}
            {% endif %}
        {% endfor %}
    {% endif %}
{% endfor %}

<div class="mobile-menu scroll-sm d-lg-none d-block">
    <button type="button" class="close-button"><i class="ph ph-x"></i></button>
    <div class="mobile-menu__inner">
        <a href="{{ routes.root_url }}" class="mobile-menu__logo">
            <img src="{{ site_logo_asset }}" alt="{{ shop.name }}" width="300" height="120" />
        </a>
        <div class="mobile-menu__menu">
            <ul class="nav-menu flex-align nav-menu--mobile">
                {% for link in linklists.main-menu.links %}
                    <li class="on-hover-item nav-menu__item{% if link.links.size > 0 %} has-submenu{% endif %}{% if link.active %} activePage{% endif %}">
                        <a href="{{ link.url }}" class="nav-menu__link text-heading-two">{{ link.title }}</a>
                        {% if link.links.size > 0 %}
                        <ul class="on-hover-dropdown common-dropdown nav-submenu scroll-sm">
                            {% for sublink in link.links %}
                                <li class="common-dropdown__item nav-submenu__item{% if sublink.active %} activePage{% endif %}">
                                    <a href="{{ sublink.url }}" class="common-dropdown__link nav-submenu__link text-heading-two hover-bg-neutral-100">{{ sublink.title }}</a>
                                </li>
                            {% endfor %}
                        </ul>
                        {% endif %}
                    </li>
                {% endfor %}

                {% unless has_hot_deals_link %}
                    <li class="on-hover-item nav-menu__item{% if request.path contains '/pages/hot-deals' %} activePage{% endif %}">
                        <a href="{{ hot_deals_url }}" class="nav-menu__link text-heading-two">{{ hot_deals_title }}</a>
                    </li>
                {% endunless %}

                {% unless has_our_brands_link %}
                    <li class="on-hover-item nav-menu__item{% if request.path contains '/pages/our-brands' %} activePage{% endif %}">
                        <a href="{{ our_brands_url }}" class="nav-menu__link text-heading-two">{{ our_brands_title }}</a>
                    </li>
                {% endunless %}

                {% unless has_partner_hub_link %}
                    <li class="on-hover-item nav-menu__item{% if request.path contains '/pages/partner_hub' or request.path contains '/pages/partner-hub' %} activePage{% endif %}">
                        <a href="{{ partner_hub_url }}" class="nav-menu__link text-heading-two">{{ partner_hub_title }}</a>
                    </li>
                {% endunless %}
            </ul>
        </div>
    </div>
</div>

<header class="header-middle border-bottom border-gray-100 z-50">
    <div class="container container-lg">
        <nav class="header-inner flex-between gap-8">
            <div class="logo">
                <a href="{{ routes.root_url }}" class="link">
                    <img src="{{ site_logo_asset }}" alt="{{ shop.name }}" width="300" height="120" />
                </a>
            </div>
            
            <form action="{{ routes.search_url }}" method="get" class="flex-align max-w-2xl flex-wrap form-location-wrapper w-100" role="search">
                <div class="search-form__wrapper position-relative w-100">
                    <input type="search" name="q" class="common-input border border-neutral-40 py-18 ps-16 pe-44 placeholder-italic placeholder-text-sm w-100" placeholder="{{ 'header.search_placeholder' | t }}" />
                    <button type="submit" class="w-64 h-44 bg-main-600 hover-bg-main-800 rounded-4 flex-center text-xl text-white position-absolute top-50 translate-middle-y inset-inline-end-0 me-6">
                        <i class="ph ph-magnifying-glass"></i>
                    </button>
                </div>
            </form>
            
            <div class="header-right flex-align flex-shrink-0">
                <div class="flex-align gap-20">
                    <button type="button" class="search-icon flex-align d-lg-none d-flex gap-4 item-hover">
                        <span class="text-2xl text-gray-700 d-flex position-relative item-hover__text">
                            <i class="ph ph-magnifying-glass"></i>
                        </span>
                    </button>
                    <button type="button" onclick="window.toggleCartDrawer()" class="flex-align gap-4 item-hover border-0 bg-transparent cursor-pointer">
                        <span class="text-xl text-gray-700 d-flex position-relative me-6 mt-6 item-hover__text">
                            <i class="ph ph-shopping-cart-simple"></i>
                            <span class="w-16 h-16 flex-center rounded-circle bg-main-600 text-white text-xs position-absolute top-n6 end-n4" data-cart-count>{{ cart.item_count }}</span>
                        </span>
                        <span class="text-md text-heading-three item-hover__text d-none d-lg-flex">{{ 'header.cart' | t }}</span>
                    </button>
                </div>
            </div>
        </nav>
    </div>
</header>

<header style="z-index: 9999 !important;" class="header bg-white border-bottom-0 box-shadow-3xl py-10 z-50">
    <div class="container container-lg">
        <nav  class="header-inner d-flex justify-content-between gap-8">
            <div class="flex-align menu-category-wrapper position-relative">
                <div>
                    <button style="background-color: #2394BE;" type="button" class="category-button d-flex align-items-center gap-12 text-white px-20 py-16 rounded-6 transition-2">
                        <span class="text-xl line-height-1"><i class="ph ph-squares-four"></i></span>
                        <span>{{ 'header.browse_categories' | t }}</span>
                        <span class="line-height-1 icon transition-2"><i class="ph-bold ph-caret-down"></i></span>
                    </button>
                    <div class="browseCat category-dropdown border border-success-200 shadow bg-white p-16 rounded-16 w-100 max-w-600 position-absolute inset-block-start-100 inset-inline-start-0 z-99 transition-2">
                        <button type="button" class="category-close-btn d-lg-none position-absolute top-0 end-0 m-8 w-32 h-32 border-0 bg-gray-100 rounded-circle flex-center text-gray-600 hover-text-gray-800 hover-bg-gray-200 transition-2" style="z-index: 1;" title="{{ 'header.close_categories' | t }}">
                            <i class="ph ph-x text-lg"></i>
                        </button>
                        <div class="d-grid gap-4 max-h-350">
                            {% assign category_count = 0 %}
                            {% for collection in collections %}
                                {% if collection.products_count > 0 and category_count < 9 %}
                                    {% assign collection_url = routes.all_products_collection_url %}
                                    {% if collection.handle != 'all' %}
                                        {% assign collection_url = routes.all_products_collection_url | append: '?collection=' | append: collection.handle %}
                                    {% endif %}
                                    <a href="{{ collection_url }}" class="py-16 px-8 rounded-8 hover-bg-main-50 d-flex flex-column align-items-center text-center border border-white hover-border-main-100">
                                        <span>
                                            {% if collection.featured_image != blank %}
                                                <img src="{{ collection.featured_image | image_url: width: 80, height: 80 }}" alt="{{ collection.title | escape }}" width="40" height="40" class="w-40" />
                                            {% else %}
                                                {{ 'image' | placeholder_svg_tag: 'placeholder-svg w-40 h-40' }}
                                            {% endif %}
                                        </span>
                                        <span class="fw-semibold text-heading mt-16 text-sm">{{ collection.title | escape }}</span>
                                    </a>
                                    {% assign category_count = category_count | plus: 1 %}
                                {% endif %}
                            {% endfor %}
                        </div>
                        <div class="mt-16 text-center">
                            <a href="{{ routes.all_products_collection_url }}" class="text-sm text-decoration-underline mt-24">
                                {{ 'header.view_all_collections' | t }}
                            </a>
                        </div>
                    </div>
                </div>
                <div class="header-menu d-lg-block d-none">
                    <ul class="nav-menu flex-align">
                        {% for link in linklists.main-menu.links %}
                            <li class="on-hover-item nav-menu__item{% if link.links.size > 0 %} has-submenu{% endif %}{% if link.active %} activePage{% endif %}">
                                <a href="{{ link.url }}" class="nav-menu__link text-heading-two">{{ link.title }}</a>
                                {% if link.links.size > 0 %}
                                <ul class="on-hover-dropdown common-dropdown nav-submenu scroll-sm">
                                    {% for sublink in link.links %}
                                        <li class="common-dropdown__item nav-submenu__item{% if sublink.active %} activePage{% endif %}">
                                            <a href="{{ sublink.url }}" class="common-dropdown__link nav-submenu__link text-heading-two hover-bg-neutral-100">{{ sublink.title }}</a>
                                        </li>
                                    {% endfor %}
                                </ul>
                                {% endif %}
                            </li>
                        {% endfor %}

                        {% unless has_hot_deals_link %}
                            <li class="on-hover-item nav-menu__item{% if request.path contains '/pages/hot-deals' %} activePage{% endif %}">
                                <a href="{{ hot_deals_url }}" class="nav-menu__link text-heading-two">{{ hot_deals_title }}</a>
                            </li>
                        {% endunless %}

                        {% unless has_our_brands_link %}
                            <li class="on-hover-item nav-menu__item{% if request.path contains '/pages/our-brands' %} activePage{% endif %}">
                                <a href="{{ our_brands_url }}" class="nav-menu__link text-heading-two">{{ our_brands_title }}</a>
                            </li>
                        {% endunless %}

                        {% unless has_partner_hub_link %}
                            <li class="on-hover-item nav-menu__item{% if request.path contains '/pages/partner_hub' or request.path contains '/pages/partner-hub' %} activePage{% endif %}">
                                <a href="{{ partner_hub_url }}" class="nav-menu__link text-heading-two">{{ partner_hub_title }}</a>
                            </li>
                        {% endunless %}
                    </ul>
                </div>
            </div>
            <div class="header-right flex-align gap-20">
                <a href="tel:{{ section.settings.phone_number }}" class="d-sm-flex align-items-center gap-16 d-none">
                    <span class="d-flex text-20">
                        {% if section.settings.phone_icon != blank %}
                            <img src="{{ section.settings.phone_icon | image_url: width: 20, height: 20 }}" alt="Phone Icon" width="20" height="20" />
                        {% endif %}
                    </span>
                    <span>
                        <span class="d-block text-heading fw-medium">{{ 'header.need_help' | t }}</span>
                        <span class="d-block fw-bold text-main-600 hover-text-decoration-underline">{{ section.settings.phone_number }}</span>
                    </span>
                </a>
                <button type="button" class="toggle-mobileMenu d-lg-none ms-3n text-gray-800 text-4xl d-flex">
                    <i class="ph ph-list"></i>
                </button>
            </div>
        </nav>
    </div>
</header>

