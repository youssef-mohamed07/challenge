<div class="carousel text-neutral-600">
  <div class="list">
    {% assign carousel_products = collections.all.products | where: 'tags', 'carousel' %}
    {% if carousel_products.size == 0 %}
      {% assign carousel_products = collections.all.products %}
    {% endif %}

    {% for product in carousel_products limit: 8 %}
      <div class="item">
        <img 
          src="{{ product.featured_image | image_url: width: 1800, height: 1800 }}" 
          width="400" height="400" alt="{{ product.title }}">
        
        <div class="introduce">
          <div class="title">{{ 'carousel.category_title' | t }}</div>
          <div class="topic">{{ product.title }}</div>
          <div class="des">
            {{ product.description | strip_html | truncate: 180 }}
          </div>
          <button class="seeMore">{{ 'carousel.see_more' | t }}</button>
        </div>

        <div class="detail">
          <div class="title">{{ product.title }}</div>
          <div class="des">
            {{ product.description }}
          </div>
          {% if product.selected_or_first_available_variant %}
            <div class="specifications">
              <div>
                <p>{{ 'carousel.specifications.weight' | t }}</p>
                <p>{{ product.selected_or_first_available_variant.weight | weight_with_unit }}</p>
              </div>
              <div>
                <p>{{ 'carousel.specifications.price' | t }}</p>
                <p>{{ product.price | money }}</p>
              </div>
              <div>
                <p>{{ 'carousel.specifications.category' | t }}</p>
                {% if product.collections.size > 0 %}
                  <p>{{ product.collections.first.title }}</p>
                {% else %}
                  <p>{{ 'carousel.specifications.no_category' | t }}</p>
                {% endif %}
              </div>
            </div>
          {% endif %}                     

          <div class="checkout">
            <form method="post" action="{{ routes.cart_add_url }}">
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <button class="addToCartBtn" type="submit">{{ 'carousel.add_to_cart' | t }}</button>
            </form>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>

  <div class="arrows">
    <button id="prev" class="flex items-center justify-center"><i class="ph-bold ph-caret-left"></i></button>
    <button id="next" class="flex items-center justify-center"><i class="ph-bold ph-caret-right"></i></button>
  </div>
  <button id="back" class="flex items-center justify-center">{{ 'carousel.back' | t }}</button>
  <a href="{{ routes.all_products_collection_url }}" class="seeAllShopBtn flex items-center justify-center">{{ 'carousel.see_all' | t }}</a>
</div>
