{% if page.handle == 'contact' %}
{% style %}
    .contact-wow {
        position: relative;
        padding: clamp(56px, 7vw, 96px) 0;
        background:
            radial-gradient(620px 280px at -8% -12%, rgba(35, 148, 190, 0.16), transparent 68%),
            radial-gradient(520px 260px at 108% 2%, rgba(72, 127, 255, 0.12), transparent 64%),
            linear-gradient(180deg, #f8fbff 0%, #eef6fb 44%, #f9fcff 100%);
        overflow: hidden;
    }

    .contact-wow::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: linear-gradient(rgba(18, 21, 53, 0.05) 1px, transparent 1px),
            linear-gradient(90deg, rgba(18, 21, 53, 0.05) 1px, transparent 1px);
        background-size: 44px 44px;
        opacity: 0.25;
        pointer-events: none;
    }

    .contact-wow .container {
        position: relative;
        z-index: 1;
    }

    .contact-wow__intro {
        max-width: 760px;
        margin: 0 auto 36px;
    }

    .contact-wow__eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 7px 14px;
        border-radius: 999px;
        background: rgba(35, 148, 190, 0.12);
        color: var(--main-700);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.8px;
        text-transform: uppercase;
    }

    .contact-wow__title {
        font-family: var(--heading-font-two);
        font-size: clamp(1.8rem, 3.2vw, 2.9rem);
        font-weight: 800;
        line-height: 1.15;
        color: var(--neutral-600);
        margin: 14px 0 10px;
    }

    .contact-wow__subtitle {
        color: var(--gray-700);
        font-size: 16px;
        line-height: 1.65;
        margin: 0;
    }

    .contact-wow__panel {
        height: 100%;
        background: rgba(255, 255, 255, 0.95);
        border: 1px solid #d9e6f2;
        border-radius: 24px;
        padding: clamp(20px, 3vw, 34px);
        box-shadow: 0 18px 40px rgba(18, 21, 53, 0.1);
        backdrop-filter: blur(8px);
    }

    .contact-wow__visual {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 24px;
    }

    .contact-wow__illustration-wrap {
        border-radius: 18px;
        background: linear-gradient(135deg, rgba(35, 148, 190, 0.1), rgba(72, 127, 255, 0.1));
        border: 1px solid #d9e6f2;
        padding: clamp(16px, 2.5vw, 24px);
    }

    .contact-wow__illustration {
        display: block;
        width: min(100%, 450px);
        height: auto;
        margin: 0 auto;
        filter: drop-shadow(0 14px 30px rgba(18, 21, 53, 0.15));
    }

    .contact-wow__chips {
        display: grid;
        gap: 12px;
    }

    .contact-wow__chip {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 16px;
        border: 1px solid #dbe8f4;
        border-radius: 14px;
        background: #fff;
        color: var(--neutral-600);
        text-decoration: none;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    }

    .contact-wow__chip:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 22px rgba(18, 21, 53, 0.1);
        border-color: var(--main-300);
    }

    .contact-wow__chip-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--main-600), #1a7ea4);
        color: #fff;
        font-size: 20px;
        flex-shrink: 0;
    }

    .contact-wow__chip-text small {
        display: block;
        margin-bottom: 2px;
        color: var(--gray-600);
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.4px;
    }

    .contact-wow__chip-text strong {
        color: var(--neutral-600);
        font-size: 14px;
        line-height: 1.45;
        font-weight: 700;
    }

    .contact-wow__form-title {
        font-family: var(--heading-font-two);
        color: var(--neutral-600);
        font-size: clamp(1.4rem, 2.4vw, 2rem);
        font-weight: 800;
        margin: 0;
    }

    .contact-wow__form-subtitle {
        margin: 8px 0 0;
        color: var(--gray-700);
        font-size: 15px;
        line-height: 1.6;
    }

    .contact-wow__label {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: var(--neutral-600);
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .contact-wow .common-input {
        min-height: 50px;
        border: 1px solid #d2e0ed;
        border-radius: 12px;
        background: #fff;
        transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
    }

    .contact-wow .common-input::placeholder {
        color: #8fa0b1;
    }

    .contact-wow .common-input:focus {
        border-color: var(--main-500);
        box-shadow: 0 0 0 4px rgba(35, 148, 190, 0.15);
        background-color: #fff;
    }

    .contact-wow textarea.common-input {
        min-height: 148px;
        padding-top: 12px;
        resize: vertical;
    }

    .contact-wow .alert {
        border-radius: 12px;
        border: 0;
        padding: 12px 14px;
    }

    .contact-wow__submit {
        display: block;
        width: min(100%, 280px);
        min-height: 56px;
        margin-inline: auto;
        border: 0;
        border-radius: 12px;
        padding: 14px 28px;
        font-size: 17px;
        font-weight: 700;
        letter-spacing: 0.4px;
        color: #fff;
        background: linear-gradient(135deg, var(--main-600), #1a7ea4);
        box-shadow: 0 12px 24px rgba(35, 148, 190, 0.28);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .contact-wow__submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 16px 28px rgba(35, 148, 190, 0.34);
    }

    .contact-wow__submit:active {
        transform: translateY(0);
    }

    @media (max-width: 991px) {
        .contact-wow__intro {
            margin-bottom: 28px;
        }

        .contact-wow__visual {
            margin-bottom: 20px;
        }
    }

    @media (max-width: 575px) {
        .contact-wow__chip {
            padding: 12px;
        }
    }
{% endstyle %}

<section class="contact contact-wow">
    <div class="container container-lg">
        <div class="contact-wow__intro text-center">
            <span class="contact-wow__eyebrow">{{ section.settings.eyebrow | escape }}</span>
            <h2 class="contact-wow__title">{{ 'contact.info.title' | t }}</h2>
            <p class="contact-wow__subtitle">{{ section.settings.subtitle | escape }}</p>
        </div>

        <div class="row g-24 align-items-stretch">
            <div class="col-lg-5">
                <div class="contact-wow__panel contact-wow__visual">
                    <div class="contact-wow__illustration-wrap">
                        <img src="{{ 'contact_1us.png' | asset_url }}" alt="Contact support illustration" width="560" height="460" class="contact-wow__illustration" loading="lazy">
                    </div>

                    <div class="contact-wow__chips">
                        <a href="tel:{{ 'contact.info.phone' | t | remove: ' ' }}" class="contact-wow__chip">
                            <span class="contact-wow__chip-icon"><i class="ph-fill ph-phone-call"></i></span>
                            <span class="contact-wow__chip-text">
                                <small>{{ 'contact.form.phone' | t }}</small>
                                <strong>{{ 'contact.info.phone' | t }}</strong>
                            </span>
                        </a>

                        <a href="mailto:{{ 'contact.info.email' | t }}" class="contact-wow__chip">
                            <span class="contact-wow__chip-icon"><i class="ph-fill ph-envelope"></i></span>
                            <span class="contact-wow__chip-text">
                                <small>{{ 'contact.form.email' | t }}</small>
                                <strong>{{ 'contact.info.email' | t }}</strong>
                            </span>
                        </a>

                        <div class="contact-wow__chip">
                            <span class="contact-wow__chip-icon"><i class="ph-fill ph-map-pin"></i></span>
                            <span class="contact-wow__chip-text">
                                <small>{{ 'contact.info.directions' | t }}</small>
                                <strong>{{ 'contact.info.address' | t }}</strong>
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="contact-wow__panel">
                    {% form 'contact' %}
                        <h6 class="contact-wow__form-title">{{ 'contact.form.title' | t }}</h6>
                        <p class="contact-wow__form-subtitle mb-28">{{ section.settings.form_helper | escape }}</p>

                        {%- if form.posted_successfully? -%}
                            <div class="alert alert-success mb-20">
                                <p class="mb-0">{{ 'contact.form.post_success' | t }}</p>
                            </div>
                        {%- endif -%}

                        {%- if form.errors -%}
                            <div class="alert alert-danger mb-20">
                                <h6 class="mb-8">{{ 'contact.form.error_heading' | t }}</h6>
                                {%- for field in form.errors -%}
                                    <p class="mb-0">{{ field | capitalize }} {{ form.errors.messages[field] }}</p>
                                {%- endfor -%}
                            </div>
                        {%- endif -%}

                        <div class="row gy-4">
                            <div class="col-md-6">
                                <label for="ContactForm-name" class="contact-wow__label">{{ 'contact.form.name' | t }} <span class="text-danger">*</span></label>
                                <input type="text" class="common-input px-16" name="contact[name]" id="ContactForm-name" placeholder="{{ 'contact.form.name_placeholder' | t }}" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" required>
                            </div>

                            <div class="col-md-6">
                                <label for="ContactForm-email" class="contact-wow__label">{{ 'contact.form.email' | t }} <span class="text-danger">*</span></label>
                                <input type="email" class="common-input px-16" name="contact[email]" id="ContactForm-email" placeholder="{{ 'contact.form.email_placeholder' | t }}" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" required>
                            </div>

                            <div class="col-md-6">
                                <label for="ContactForm-phone" class="contact-wow__label">{{ 'contact.form.phone' | t }} <span class="text-danger">*</span></label>
                                <input type="tel" class="common-input px-16" name="contact[phone]" id="ContactForm-phone" placeholder="{{ 'contact.form.phone_placeholder' | t }}" value="{% if form.phone %}{{ form.phone }}{% endif %}" required>
                            </div>

                            <div class="col-md-6">
                                <label for="ContactForm-subject" class="contact-wow__label">{{ 'contact.form.subject' | t }} <span class="text-danger">*</span></label>
                                <input type="text" class="common-input px-16" name="contact[subject]" id="ContactForm-subject" placeholder="{{ 'contact.form.subject_placeholder' | t }}" value="{% if form.subject %}{{ form.subject }}{% endif %}" required>
                            </div>

                            <div class="col-12">
                                <label for="ContactForm-body" class="contact-wow__label">{{ 'contact.form.message' | t }} <span class="text-danger">*</span></label>
                                <textarea class="common-input px-16" name="contact[body]" id="ContactForm-body" placeholder="{{ 'contact.form.message_placeholder' | t }}" required>{% if form.body %}{{ form.body }}{% endif %}</textarea>
                            </div>

                            <div class="col-12 mt-10">
                                <button type="submit" class="btn contact-wow__submit">{{ 'contact.form.send' | t }}</button>
                            </div>
                        </div>
                    {% endform %}
                </div>
            </div>
        </div>
    </div>
</section>
{% endif %}

{% schema %}
{
    "name": "Contact Us",
    "settings": [
        {
            "type": "text",
            "id": "eyebrow",
            "label": "Eyebrow",
            "default": "Need help?"
        },
        {
            "type": "textarea",
            "id": "subtitle",
            "label": "Intro text",
            "default": "Have a question about products, orders, or support? Send us a message and our team will get back to you quickly."
        },
        {
            "type": "textarea",
            "id": "form_helper",
            "label": "Form helper text",
            "default": "We usually reply within 24 hours."
        }
    ]
}
{% endschema %}