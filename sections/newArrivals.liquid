{% assign new_products = collections.all.products | where: 'tags', 'new' %}
{% if new_products.size == 0 %}
  {% assign new_products = collections.all.products %}
{% endif %}

<section class="new-arrivals mb-80">
  <div class="container container-lg">
    <div class="new-arrivals__head">
      <h2 class="new-arrivals__title">New Arrivals</h2>
      <a href="{{ routes.all_products_collection_url }}" class="new-arrivals__view-all">View all</a>
    </div>

    {% if new_products.size > 0 %}
      <div class="new-arrivals__grid" role="list">
        <a href="{{ routes.all_products_collection_url }}" class="new-arrivals__promo-card new-arrivals__promo-card--primary" role="listitem">
          <img src="{{ '1.png' | asset_url }}" alt="New arrivals campaign" width="620" height="820" loading="lazy">
          <span class="new-arrivals__promo-overlay"></span>
          <span class="new-arrivals__promo-content new-arrivals__promo-content--primary">
            <strong>Every Scoop</strong>
            <em>Shop Now</em>
          </span>
        </a>

        {% for product in new_products limit: 6 %}
          <div class="new-arrivals__item" role="listitem">
            {% render 'product-card', product: product %}
          </div>
        {% endfor %}

        <a href="{{ routes.all_products_collection_url }}" class="new-arrivals__promo-card new-arrivals__promo-card--secondary" role="listitem">
          <img src="{{ '2.png' | asset_url }}" alt="New arrivals secondary campaign" width="620" height="820" loading="lazy">
          <span class="new-arrivals__promo-overlay"></span>
          <span class="new-arrivals__promo-content new-arrivals__promo-content--secondary">
            <strong>A Step Ahead</strong>
            <em>Shop Now</em>
          </span>
        </a>
      </div>
    {% else %}
      <div class="new-arrivals__empty">No products available yet.</div>
    {% endif %}
  </div>
</section>

<style>
.new-arrivals {
  padding-inline: 8px;
}

.new-arrivals__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 26px;
}

.new-arrivals__title {
  margin: 0;
  font-family: var(--heading-font-two);
  font-size: clamp(2rem, 3vw, 3rem);
  font-weight: 800;
  color: var(--neutral-600);
  letter-spacing: 0.4px;
  text-transform: uppercase;
}

.new-arrivals__view-all {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42px;
  padding: 8px 16px;
  border-radius: 999px;
  font-size: 13px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.4px;
  color: #fff;
  text-decoration: none;
  background: linear-gradient(135deg, var(--main-600), #1a7ea4);
  box-shadow: 0 10px 22px rgba(35, 148, 190, 0.24);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.new-arrivals__view-all:hover {
  color: #fff;
  transform: translateY(-2px);
  box-shadow: 0 14px 26px rgba(35, 148, 190, 0.3);
}

.new-arrivals__promo-card {
  position: relative;
  display: block;
  overflow: hidden;
  min-height: 372px;
  border-radius: 14px;
  border: 1px solid #c9ddef;
  background: #d8ecf9;
  text-decoration: none;
  isolation: isolate;
  box-shadow: 0 10px 24px rgba(14, 44, 78, 0.12);
}

.new-arrivals__promo-card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transform: scale(1);
  transition: transform 0.35s ease;
}

.new-arrivals__promo-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(165deg, rgba(9, 16, 39, 0.2), rgba(6, 16, 40, 0.62));
  z-index: 1;
}

.new-arrivals__promo-content {
  position: absolute;
  inset-inline: 22px;
  z-index: 2;
  display: grid;
  gap: 12px;
}

.new-arrivals__promo-content--primary {
  bottom: 32px;
}

.new-arrivals__promo-content--secondary {
  bottom: 28px;
}

.new-arrivals__promo-content strong {
  color: #fff;
  font-family: var(--heading-font-two);
  font-size: clamp(1.55rem, 2.5vw, 2.8rem);
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 1px;
  line-height: 1.02;
}

.new-arrivals__promo-content em {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: fit-content;
  min-height: 44px;
  padding: 8px 24px;
  border-radius: 999px;
  color: #fff;
  font-style: normal;
  font-weight: 700;
  background: linear-gradient(135deg, #2454e6, #1f3ca8);
  box-shadow: 0 8px 20px rgba(25, 49, 135, 0.4);
}

.new-arrivals__promo-card:hover img {
  transform: scale(1.06);
}

.new-arrivals__grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16px;
  align-items: stretch;
}

.new-arrivals__promo-card--primary {
  grid-column: 1;
  grid-row: 1;
}

.new-arrivals__promo-card--secondary {
  grid-column: 4;
  grid-row: 2;
}

.new-arrivals__item {
  display: flex;
}

.new-arrivals__item .product-card {
  width: 100%;
  max-width: none;
  margin-bottom: 0;
}

.new-arrivals__empty {
  min-height: 220px;
  border: 1px dashed #c9d8e6;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--gray-600);
  font-weight: 600;
  background: #f7fbff;
}

@media (max-width: 1199px) {
  .new-arrivals__grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .new-arrivals__promo-card--primary,
  .new-arrivals__promo-card--secondary {
    grid-column: auto;
    grid-row: auto;
  }

  .new-arrivals__promo-card {
    min-height: 340px;
  }
}

@media (max-width: 991px) {
  .new-arrivals__grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .new-arrivals__promo-card {
    min-height: 320px;
  }

  .new-arrivals__promo-content strong {
    font-size: clamp(1.2rem, 4.4vw, 2.1rem);
  }
}

@media (max-width: 767px) {
  .new-arrivals__head {
    flex-direction: column;
    align-items: flex-start;
  }

  .new-arrivals__grid {
    grid-template-columns: 1fr;
  }

  .new-arrivals__promo-card {
    min-height: 280px;
  }
}
</style>
