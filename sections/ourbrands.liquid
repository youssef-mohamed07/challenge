{% assign current_page_handle = page.handle | default: '' %}
{% assign fallback_brand_assets = '1.webp,2.avif,3.webp,4.webp,5.webp,6.webp,7.webp,8.webp,9.webp' | split: ',' %}
{% if current_page_handle == 'our-brands' %}
{% comment %} Our Brands Section {% endcomment %}
<section class="brands py-80 our-brands-page">
  <div class="container container-lg">
    {% if section.settings.heading != blank %}
      <div class="section-heading text-center mb-48">
        <h2 style="font-family: 'Poppins', sans-serif; font-weight: 500;" class="mb-12">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="text-gray-600">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="row g-24 our-brands-page__grid">
      {% assign vendor_names = collections.all.products | map: 'vendor' | uniq %}
      {% assign rendered_brand_cards = 0 %}
      {% assign target_cards = section.settings.auto_fill_cards | default: 9 %}

      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'brand' %}
            {% assign fallback_index = rendered_brand_cards | modulo: fallback_brand_assets.size %}
            {% assign fallback_asset = fallback_brand_assets[fallback_index] | strip %}
            {% assign block_brand_name = block.settings.brand_name | strip %}
            {% if block_brand_name == blank %}
              {% assign block_brand_name = vendor_names[rendered_brand_cards] | strip %}
            {% endif %}
            {% if block_brand_name == blank %}
              {% assign block_brand_number = rendered_brand_cards | plus: 1 %}
              {% assign block_brand_name = 'Brand ' | append: block_brand_number %}
            {% endif %}

            <div class="col-lg-{{ section.settings.columns_desktop }} col-md-6 mb-24" {{ block.shopify_attributes }}>
              <div class="vendors-two-item rounded-12 overflow-hidden bg-color-three border border-neutral-50 hover-border-main-two-600 transition-2">
                <div class="vendors-two-item__top bg-overlay style-two position-relative">
                  <div class="vendors-two-item__thumbs h-210">
                    {% if block.settings.brand_image != blank %}
                      {{ block.settings.brand_image | image_url: width: 400, height: 210 | image_tag: alt: block_brand_name, class: 'cover-img', width: '400', height: '210' }}
                    {% elsif fallback_asset != blank %}
                      <img src="{{ fallback_asset | asset_url }}" alt="{{ block_brand_name | escape }}" class="cover-img" width="400" height="210" loading="lazy">
                    {% else %}
                      <img src="{{ 'placeholder.svg' | asset_url }}" alt="{{ block_brand_name | escape }}" class="cover-img" width="400" height="210" loading="lazy">
                    {% endif %}
                  </div>
                  <div class="position-absolute top-0 inset-inline-start-0 w-100 h-100 p-24 z-1 d-flex flex-column justify-content-end">
                    <div class="d-flex align-items-center justify-content-start gap-16">
                      {% if block.settings.brand_logo != blank %}
                        <span class="w-80 h-80 flex-center bg-white rounded-circle flex-shrink-0">
                          {{ block.settings.brand_logo | image_url: width: 60, height: 60 | image_tag: alt: block_brand_name, width: '60', height: '60' }}
                        </span>
                      {% elsif fallback_asset != blank %}
                        <span class="w-80 h-80 flex-center bg-white rounded-circle flex-shrink-0">
                          <img src="{{ fallback_asset | asset_url }}" alt="{{ block_brand_name | escape }}" width="60" height="60" loading="lazy">
                        </span>
                      {% endif %}
                      <div>
                        <h6 class="text-white fw-semibold mb-4">
                          {% if block.settings.brand_url != blank %}
                            <a href="{{ block.settings.brand_url }}" class="text-white hover-text-main-two-600">{{ block_brand_name }}</a>
                          {% else %}
                            {{ block_brand_name }}
                          {% endif %}
                        </h6>
                        {% if block.settings.brand_address != blank %}
                          <div class="flex-align gap-8">
                            <span class="flex-center text-main-two-600 text-lg flex-shrink-0">
                              <i class="ph ph-map-pin-line"></i>
                            </span>
                            <p class="text-sm text-white">{{ block.settings.brand_address }}</p>
                          </div>
                        {% endif %}
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            {% assign rendered_brand_cards = rendered_brand_cards | plus: 1 %}
        {% endcase %}
      {% endfor %}

      {% if rendered_brand_cards < target_cards %}
        {% for slot in (0..20) %}
          {% if rendered_brand_cards >= target_cards %}
            {% break %}
          {% endif %}

          {% assign fallback_index = rendered_brand_cards | modulo: fallback_brand_assets.size %}
          {% assign fallback_asset = fallback_brand_assets[fallback_index] | strip %}
          {% assign fallback_vendor_name = vendor_names[rendered_brand_cards] | strip %}
          {% if fallback_vendor_name == blank %}
            {% assign fallback_brand_number = rendered_brand_cards | plus: 1 %}
            {% assign fallback_vendor_name = 'Brand ' | append: fallback_brand_number %}
          {% endif %}

          <div class="col-lg-{{ section.settings.columns_desktop }} col-md-6 mb-24">
            <div class="vendors-two-item rounded-12 overflow-hidden bg-color-three border border-neutral-50 hover-border-main-two-600 transition-2">
              <div class="vendors-two-item__top bg-overlay style-two position-relative">
                <div class="vendors-two-item__thumbs h-210">
                  {% if fallback_asset != blank %}
                    <img src="{{ fallback_asset | asset_url }}" alt="{{ fallback_vendor_name | escape }}" class="cover-img" width="400" height="210" loading="lazy">
                  {% else %}
                    <img src="{{ 'placeholder.svg' | asset_url }}" alt="{{ fallback_vendor_name | escape }}" class="cover-img" width="400" height="210" loading="lazy">
                  {% endif %}
                </div>
                <div class="position-absolute top-0 inset-inline-start-0 w-100 h-100 p-24 z-1 d-flex flex-column justify-content-end">
                  <div class="d-flex align-items-center justify-content-start gap-16">
                    {% if fallback_asset != blank %}
                      <span class="w-80 h-80 flex-center bg-white rounded-circle flex-shrink-0">
                        <img src="{{ fallback_asset | asset_url }}" alt="{{ fallback_vendor_name | escape }}" width="60" height="60" loading="lazy">
                      </span>
                    {% endif %}
                    <div>
                      <h6 class="text-white fw-semibold mb-4">{{ fallback_vendor_name }}</h6>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          {% assign rendered_brand_cards = rendered_brand_cards | plus: 1 %}
        {% endfor %}
      {% endif %}

      {% if rendered_brand_cards == 0 %}
        <div class="col-12">
          <div class="our-brands-page__vendor-fallback rounded-12 border border-neutral-50 p-24 text-center">
            <h6 class="mb-0 text-heading">Add brands from theme editor</h6>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</section>
{% endif %}

{% stylesheet %}
.our-brands-page .vendors-two-item {
  box-shadow: 0 8px 22px rgba(15, 23, 42, 0.08);
}

.our-brands-page__vendor-fallback {
  background: linear-gradient(180deg, #fbfdff 0%, #f4f8fc 100%);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.our-brands-page__vendor-media {
  width: 84px;
  height: 84px;
  border-radius: 999px;
  background: #fff;
  border: 1px solid #d9e6f2;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12px;
  overflow: hidden;
}

.our-brands-page__vendor-media img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  padding: 8px;
}

.our-brands-page__vendor-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 30px;
  padding: 4px 12px;
  border-radius: 999px;
  background: #1e89b2;
  color: #fff;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.4px;
  text-transform: uppercase;
}
{% endstylesheet %}

{% schema %}
{
  "name": "Our Brands",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Our Brands",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "options": [
        {
          "value": "12",
          "label": "1 column"
        },
        {
          "value": "6",
          "label": "2 columns"
        },
        {
          "value": "4",
          "label": "3 columns"
        },
        {
          "value": "3",
          "label": "4 columns"
        }
      ],
      "default": "4",
      "label": "Columns"
    },
    {
      "type": "range",
      "id": "auto_fill_cards",
      "label": "Auto-fill cards count",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 9
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "text",
          "id": "brand_name",
          "default": "Brand Name",
          "label": "Brand name"
        },
        {
          "type": "image_picker",
          "id": "brand_image",
          "label": "Brand background image"
        },
        {
          "type": "image_picker",
          "id": "brand_logo",
          "label": "Brand logo"
        },
        {
          "type": "text",
          "id": "brand_address",
          "label": "Brand address"
        },
        {
          "type": "url",
          "id": "brand_url",
          "label": "Brand URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Our Brands",
      "blocks": [
        {
          "type": "brand",
          "settings": {
            "brand_name": "Nutrition Plus",
            "brand_address": "123 Health Street, Wellness City"
          }
        },
        {
          "type": "brand",
          "settings": {
            "brand_name": "Fit Life",
            "brand_address": "456 Fitness Avenue, Gym Town"
          }
        },
        {
          "type": "brand",
          "settings": {
            "brand_name": "Pure Supplements",
            "brand_address": "789 Vitamin Road, Health Hub"
          }
        },
        {
          "type": "brand",
          "settings": {
            "brand_name": "Active Nutrition",
            "brand_address": "321 Energy Lane, Sport City"
          }
        }
      ]
    }
  ]
}
{% endschema %}